    "uuid": "^8.0.0"
  },
  "devDependencies": {
    "@adobe/aio-cli": "11.0.1",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.0.3",
    "@semantic-release/git": "^10.0.1",
    "dotenv": "17.3.1",
    "dotenv-cli": "11.0.0",
    "eslint": "^8",
